+<script>
+  type Theme = 'auto' | 'dark' | 'light';
+
+  const storageKey = 'starlight-theme';
+
+  function parseTheme(theme: unknown): Theme {
+    return theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto';
+  }
+
+  function loadTheme(): Theme {
+    return parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));
+  }
+
+  function storeTheme(theme: Theme): void {
+    if (typeof localStorage !== 'undefined') {
+      localStorage.setItem(storageKey, theme === 'light' || theme === 'dark' ? theme : '');
+    }
+  }
+
+  function getPreferredColorScheme(): Theme {
+    return matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
+  }
+
+  function applyTheme(theme: Theme): void {
+    document.documentElement.dataset['theme'] = theme === 'auto' ? getPreferredColorScheme() : theme;
+    storeTheme(theme);
+    // Keep any native Starlight pickers (other breakpoints/fallbacks) in sync.
+    (window as any).StarlightThemeProvider?.updatePickers?.(theme);
+  }
+
+  const labels: Record<Theme, string> = { auto: 'Auto', light: 'Light', dark: 'Dark' };
+
+  customElements.define(
+    'starlight-charm-theme-select',
+    class StarlightCharmThemeSelect extends HTMLElement {
+      #trigger = this.querySelector<HTMLButtonElement>('.charm-theme-trigger')!;
+      #menu = this.querySelector<HTMLUListElement>('.charm-theme-menu')!;
+      #options = [...this.querySelectorAll<HTMLLIElement>('.charm-theme-option')];
+      #iconSlot = this.querySelector<HTMLElement>('[data-theme-icon]')!;
+      #labelSlot = this.querySelector<HTMLElement>('[data-theme-label]')!;
+
+      constructor() {
+        super();
+        const current = loadTheme();
+        applyTheme(current);
+        this.#reflect(current);
+
+        this.#trigger.addEventListener('click', () => this.#toggle());
+
+        for (const option of this.#options) {
+          option.addEventListener('click', () => {
+            const value = parseTheme(option.dataset['value']);
+            applyTheme(value);
+            this.#reflect(value);
+            this.#close(true);
+          });
+        }
+
+        // Dismissal: outside click and Escape; basic arrow-key navigation.
+        document.addEventListener('click', (e) => {
+          if (!this.contains(e.target as Node)) this.#close();
+        });
+        this.addEventListener('keydown', (e) => {
+          if (e.key === 'Escape') {
+            this.#close(true);
+          } else if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
+            e.preventDefault();
+            this.#move(e.key === 'ArrowDown' ? 1 : -1);
+          } else if ((e.key === 'Enter' || e.key === ' ') && document.activeElement instanceof HTMLLIElement) {
+            e.preventDefault();
+            (document.activeElement as HTMLLIElement).click();
+          }
+        });
+
+        // React to system scheme changes while in 'auto'.
+        matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
+          if (loadTheme() === 'auto') applyTheme('auto');
+        });
+      }
+
+      #reflect(theme: Theme) {
+        const active = this.#options.find((o) => o.dataset['value'] === theme) ?? this.#options[0]!;
+        this.#iconSlot.innerHTML = active.querySelector('svg')?.outerHTML ?? '';
+        this.#labelSlot.textContent = labels[theme];
+        for (const option of this.#options) {
+          const selected = option.dataset['value'] === theme;
+          option.setAttribute('aria-selected', String(selected));
+          option.classList.toggle('is-active', selected);
+        }
+      }
+
+      #toggle() {
+        this.#menu.hidden ? this.#open() : this.#close();
+      }
+
+      #open() {
+        this.#menu.hidden = false;
+        this.#trigger.setAttribute('aria-expanded', 'true');
+        const selected = this.#options.find((o) => o.getAttribute('aria-selected') === 'true') ?? this.#options[0]!;
+        selected.focus();
+      }
+
+      #close(returnFocus = false) {
+        if (this.#menu.hidden) return;
+        this.#menu.hidden = true;
+        this.#trigger.setAttribute('aria-expanded', 'false');
+        if (returnFocus) this.#trigger.focus();
+      }
+
+      #move(delta: number) {
+        if (this.#menu.hidden) this.#open();
+        const focused = this.#options.findIndex((o) => o === document.activeElement);
+        const next = (focused + delta + this.#options.length) % this.#options.length;
+        this.#options[next]!.focus();
+      }
+    },
+  );
+</script>
